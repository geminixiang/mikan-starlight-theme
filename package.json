{
  "name": "starlight-theme-mikan",
  "version": "0.1.0",
  "description": "A polished SaaS-style Astro Starlight theme for mikan docs.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./agent-markdown": "./src/agent-markdown.ts",
    "./agent-markdown/TableOfContents": "./src/agent-markdown/TableOfContents.astro",
    "./agent-markdown/index-endpoint": "./src/agent-markdown/index-endpoint.ts",
    "./agent-markdown/slug-endpoint": "./src/agent-markdown/slug-endpoint.ts",
    "./agent-markdown/middleware": "./src/agent-markdown/middleware.ts",
    "./components/*.astro": "./src/components/*.astro",
    "./styles/index.css": "./src/styles/index.css",
    "./themes/mikan": "./src/themes/mikan.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "pnpm run typecheck",
    "dev": "pnpm --filter mikan-starlight-theme-demo dev",
    "demo:build": "pnpm --filter mikan-starlight-theme-demo build",
    "demo:preview": "pnpm --filter mikan-starlight-theme-demo preview",
    "preview": "pnpm --filter mikan-starlight-theme-demo preview",
    "demo:check": "pnpm --filter mikan-starlight-theme-demo check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "pack:dry": "pnpm pack --dry-run",
    "test": "pnpm run typecheck && pnpm run demo:check && pnpm run demo:build && pnpm run pack:dry"
  },
  "peerDependencies": {
    "@astrojs/starlight": ">=0.39.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/starlight": "^0.39.2",
    "astro": "^6.3.5",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "keywords": [
    "astro",
    "starlight",
    "starlight-theme",
    "documentation",
    "mikan"
  ],
  "packageManager": "pnpm@10.26.0"
}
