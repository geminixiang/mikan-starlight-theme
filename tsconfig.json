{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "types": ["astro/client"]
  },
  "include": ["src/**/*.ts", "src/**/*.astro", "src/**/*.d.ts"],
  "exclude": ["dist", "node_modules", "demo"]
}
