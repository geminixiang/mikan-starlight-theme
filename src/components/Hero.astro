---
/**
 * Landing hero for mikan-starlight-theme.
 *
 * Use on a `template: splash` page. Title and tagline can be passed as props
 * or via the default slot for richer markup.
 *
 * <Hero
 *   eyebrow="Astro Starlight theme"
 *   title="Docs that read like a well-set book"
 *   tagline="Crisp editorial typography on a calm, ink-on-paper canvas."
 *   actions={[
 *     { text: "Get started", href: "/guide/theme-setup/", variant: "primary" },
 *     { text: "View fixtures", href: "/guide/visual-fixture/" },
 *   ]}
 * />
 */
interface Action {
  text: string;
  href: string;
  variant?: "primary" | "secondary";
}

interface Props {
  eyebrow?: string;
  title?: string;
  tagline?: string;
  actions?: Action[];
}

const { eyebrow, title, tagline, actions = [] } = Astro.props;
---

<section class="mikan-hero not-content">
  {eyebrow && <span class="mikan-hero-eyebrow">{eyebrow}</span>}
  {title ? <h1>{title}</h1> : <slot name="title" />}
  {tagline ? <p>{tagline}</p> : <slot name="tagline" />}
  <slot />
  {
    actions.length > 0 && (
      <div class="mikan-hero-actions">
        {actions.map((action) => (
          <a
            class:list={[
              "mikan-btn",
              action.variant === "secondary"
                ? "mikan-btn-secondary"
                : "mikan-btn-primary",
            ]}
            href={action.href}
          >
            {action.text}
          </a>
        ))}
      </div>
    )
  }
</section>
